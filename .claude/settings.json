{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "MultiEdit(*)",
      "Delete(*)",
      "WebFetch(*)",
      "WebSearch",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(find * -name *)",
      "Bash(find * -type *)",
      "Bash(find * -maxdepth *)",
      "Bash(ls *)",
      "Bash(cat *)"
    ],
    "deny": [
      "Bash(find * -exec *)",
      "Bash(find * -execdir *)",
      "Bash(find * -delete*)",
      "Bash(curl * | sh*)",
      "Bash(wget * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | bash*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Write(**/.env)",
      "Write(**/.env.*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/logs && for f in .claude/logs/*.log; do [ -f \"$f\" ] || continue; SIZE=$(wc -c < \"$f\" 2>/dev/null || echo 0); if [ \"$SIZE\" -gt 1048576 ]; then ts=$(date +%Y%m%d-%H%M%S); mv \"$f\" \"${f%.log}.${ts}.log\"; fi; done; find .claude/logs -name '*.log' -mtime +30 -delete 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/logs && echo '[pre-bash]' >> .claude/logs/tool.log"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/logs && echo '[post-edit]' >> .claude/logs/edit.log"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/logs && echo '[session-stop]' >> .claude/logs/session.log"
          }
        ]
      }
    ]
  },
  "disableSkillShellExecution": false
}
