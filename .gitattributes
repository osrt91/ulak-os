# Default: auto-detect text files, normalize to LF
* text=auto eol=lf

# Shell scripts must be LF
*.sh text eol=lf

# PowerShell scripts must be CRLF
*.ps1 text eol=crlf

# Batch files must be CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Markdown is text
*.md text eol=lf

# JSON/YAML/TOML
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
