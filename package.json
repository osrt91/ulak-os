{
  "name": "ulak-os",
  "version": "1.0.0",
  "description": "Vendor-neutral prompt operating system CLI — audit, govern, scaffold full-stack SaaS across Claude Code / Codex / Gemini CLI",
  "type": "module",
  "bin": {
    "ulak": "./dist/cli/index.js",
    "ulak-os": "./dist/cli/index.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "lint": "eslint src/",
    "prepublishOnly": "npm run build && npm test",
    "start": "node dist/cli/index.js"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "prompt",
    "ai",
    "cli",
    "operating-system",
    "vendor-neutral",
    "claude-code",
    "gemini-cli",
    "codex-cli",
    "audit",
    "scaffolder",
    "governance"
  ],
  "author": "Oğuzhan Sert <info@oguzhansert.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/osrt91/ulak-os.git"
  },
  "bugs": {
    "url": "https://github.com/osrt91/ulak-os/issues",
    "email": "info@oguzhansert.dev"
  },
  "homepage": "https://github.com/osrt91/ulak-os#readme"
}
