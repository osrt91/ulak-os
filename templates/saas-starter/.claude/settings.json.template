{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "{{product_name_pascal}} — Claude Code project settings. See docs/governance/settings-permissions-governance.md for the authoring rules.",
  "permissions": {
    "allow": [
      "Read(**)",
      "Glob(**)",
      "Grep(**)",
      "Edit(**)",
      "Write(**)",
      "Bash(git:*)",
      "Bash(pnpm:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:* -name *)",
      "Bash(find:* -type *)",
      "Bash(docker compose ps)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose build:*)",
      "Bash(docker compose restart:*)",
      "Bash(supabase:*)",
      "WebFetch(domain:docs.claude.com)",
      "WebFetch(domain:nextjs.org)",
      "WebFetch(domain:supabase.com)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(curl * | sh)",
      "Bash(wget * | sh)",
      "Bash(docker compose run*)",
      "Bash(docker compose exec*)",
      "Bash(docker run*)",
      "Bash(docker exec*)",
      "Bash(find * -exec *)",
      "Bash(find * -execdir *)",
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p .claude/logs && for f in .claude/logs/*.log; do [ -f \"$f\" ] || continue; SIZE=$(wc -c < \"$f\" 2>/dev/null || echo 0); if [ \"$SIZE\" -gt 1048576 ]; then ts=$(date +%Y%m%d-%H%M%S); mv \"$f\" \"${f%.log}.${ts}.log\"; fi; done; find .claude/logs -name '*.log' -mtime +30 -delete 2>/dev/null || true"
          }
        ]
      }
    ]
  },
  "disableSkillShellExecution": true
}
