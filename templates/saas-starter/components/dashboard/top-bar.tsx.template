  const { theme, setTheme } = useTheme();
  const actions = quickActionsByRole[role];

  return (
    <header className="sticky top-0 z-20 flex h-16 items-center gap-3 border-b border-border bg-surface/80 px-4 backdrop-blur sm:px-6">
      {/* Search / cmd-k */}
      <button
