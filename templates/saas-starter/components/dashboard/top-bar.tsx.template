                <Globe className="size-4" />
                <span className="ms-2">Dil</span>
              </DropdownMenuSubTrigger>
              <DropdownMenuSubContent>
                <DropdownMenuItem asChild>
                  <Link href="?lang=tr">
                    {locale === "tr" && <Check className="size-4 me-2" />}
                    <span className={locale === "tr" ? "" : "ms-6"}>Türkçe</span>
                  </Link>
                </DropdownMenuItem>
                <DropdownMenuItem asChild>
                  <Link href="?lang=en">
                    {locale === "en" && <Check className="size-4 me-2" />}
                    <span className={locale === "en" ? "" : "ms-6"}>English</span>
                  </Link>
                </DropdownMenuItem>
              </DropdownMenuSubContent>
            </DropdownMenuSub>

            <DropdownMenuSeparator />
            <DropdownMenuItem onClick={onLogout}>
              <LogOut className="size-4" />
              Çıkış yap
            </DropdownMenuItem>
          </DropdownMenuContent>
        </DropdownMenu>
      </div>
    </header>
  );
