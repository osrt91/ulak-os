type Role = "customer" | "admin" | "partner";

export interface TopBarProps {
  role: Role;
  user: { name: string; email: string; imageUrl?: string };
  locale?: "tr" | "en";
  unreadCount?: number;
  onLogout?: () => void;
  onOpenCommand?: () => void;
