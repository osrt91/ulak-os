const quickActionsByRole: Record<Role, { label: string; href: string }[]> = {
  customer: [{ label: "Yeni proje", href: "/dashboard/projects/new" }, { label: "Fatura indir", href: "/dashboard/billing" }],
  admin:    [{ label: "Kullanıcı davet et", href: "/admin/users/new" }, { label: "Audit log", href: "/admin/audit" }],
  partner:  [{ label: "Alt-bayi ekle", href: "/partner/sub-users/new" }, { label: "Aylık rapor", href: "/partner/reports" }],
