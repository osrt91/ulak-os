            </DropdownMenuItem>
            <DropdownMenuItem asChild>
              <Link href="/dashboard/settings">
                <Settings className="size-4" />
                Ayarlar
              </Link>
            </DropdownMenuItem>
            <DropdownMenuSeparator />

            {/* Theme */}
            <DropdownMenuSub>
              <DropdownMenuSubTrigger>
                {theme === "dark" ? <Moon className="size-4" /> : theme === "light" ? <Sun className="size-4" /> : <Monitor className="size-4" />}
                <span className="ms-2">Tema</span>
              </DropdownMenuSubTrigger>
              <DropdownMenuSubContent>
                <DropdownMenuRadioGroup value={theme} onValueChange={setTheme}>
                  <DropdownMenuRadioItem value="light"><Sun className="size-4 me-2" />Açık</DropdownMenuRadioItem>
                  <DropdownMenuRadioItem value="dark"><Moon className="size-4 me-2" />Koyu</DropdownMenuRadioItem>
                  <DropdownMenuRadioItem value="system"><Monitor className="size-4 me-2" />Sistem</DropdownMenuRadioItem>
                </DropdownMenuRadioGroup>
              </DropdownMenuSubContent>
