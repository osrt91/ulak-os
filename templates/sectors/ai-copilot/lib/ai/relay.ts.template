import 'server-only'

import { createAdminClient } from '@/lib/supabase/admin'
import { checkBudget, estimatePendingCost, CostCapExceededError } from '@/lib/ai/cost-cap'

// {{product_name_pascal}} — provider-agnostic LLM relay
//
// Contract:
//   - stream() accepts messages + options, returns a ReadableStream<Uint8Array>
//     of SSE-encoded token deltas.
//   - Pre-flight: validate model against model_allowlist; estimate cost;
//     enforce cost-cap (AP-AI-01); abort if breach.
//   - Post-flight: count actual tokens; write ai_usage_log row; increment
//     conversation totals. AP-AI-02 prevention — no un-logged calls.
//   - Errors: relay returns a stream that emits a single {error} event so the
//     client can render a fallback; errors are ALSO logged to ai_usage_log with
//     the `error` column populated (for ops debugging).

export type Provider = 'anthropic' | 'openai' | 'google'

export interface RelayMessage { role: 'system' | 'user' | 'assistant'; content: string }

export interface StreamOptions {
  provider: Provider
  model: string
  temperature?: number
  max_tokens?: number
  /** Tenant + user context — required for gating + logging */
  tenantId: string
  userId: string
  conversationId: string
  tier: string
}

export interface StreamOutcome {
  stream: ReadableStream<Uint8Array>
  /** Resolved after the stream ends with final token counts + cost + DB write. */
  finalized: Promise<{ tokens_input: number; tokens_output: number; cost_cents: number; error?: string }>
}

interface AllowlistRow {
  rate_cents_per_input_1k: number
  rate_cents_per_output_1k: number
  max_tokens_per_request: number
}

async function resolveAllowlist(tenantId: string, provider: Provider, model: string): Promise<AllowlistRow> {
  const supabase = createAdminClient()
  const { data } = await supabase
    .from('model_allowlist')
    .select('rate_cents_per_input_1k, rate_cents_per_output_1k, max_tokens_per_request')
    .eq('tenant_id', tenantId)
    .eq('provider', provider)
    .eq('model', model)
    .maybeSingle()
  if (!data) throw new Error(`model-not-allowed:${provider}:${model}`)
  return data as AllowlistRow
}

// Lightweight token counter (real implementation uses tokenizer per provider).
// For scaffolder baseline, assume ~4 chars = 1 token (conservative English).
function approxTokens(text: string): number { return Math.ceil(text.length / 4) }

async function callProvider(
  opts: StreamOptions,
  messages: RelayMessage[],
  allowlist: AllowlistRow
): Promise<ReadableStream<Uint8Array>> {
  const maxTokens = Math.min(opts.max_tokens ?? 1024, allowlist.max_tokens_per_request)
  // Per-provider fetch is generated by scaffolder. Keeping a single switch
  // here to keep the interface tight and make provider swap a one-liner.
  switch (opts.provider) {
    case 'anthropic':
      return callAnthropic(opts.model, messages, { temperature: opts.temperature, max_tokens: maxTokens })
    case 'openai':
      return callOpenAi(opts.model, messages, { temperature: opts.temperature, max_tokens: maxTokens })
    case 'google':
      return callGoogle(opts.model, messages, { temperature: opts.temperature, max_tokens: maxTokens })
  }
}

export async function stream(messages: RelayMessage[], options: StreamOptions): Promise<StreamOutcome> {
  const supabase = createAdminClient()
  const allowlist = await resolveAllowlist(options.tenantId, options.provider, options.model)

  // Estimate pending cost for gate
  const tokensInEst = messages.reduce((a, m) => a + approxTokens(m.content), 0)
  const tokensOutEst = options.max_tokens ?? 1024
  const pending = estimatePendingCost({
    tokensInputEstimate: tokensInEst,
    tokensOutputEstimate: tokensOutEst,
    rateCentsPerInput1k: allowlist.rate_cents_per_input_1k,
    rateCentsPerOutput1k: allowlist.rate_cents_per_output_1k,
  })

  try {
    await checkBudget({
      tenantId: options.tenantId,
      userId: options.userId,
      tier: options.tier,
      pendingCostCents: pending,
    })
  } catch (e) {
    if (e instanceof CostCapExceededError) {
      // Return a stream that emits error-SSE immediately + log 0-cost error row
      const errStream = errorStream(`cost-cap-exceeded:${e.remainingCents()}`)
      const finalized = (async () => {
        await supabase.from('ai_usage_log').insert({
          tenant_id: options.tenantId, user_id: options.userId,
          conversation_id: options.conversationId,
          provider: options.provider, model: options.model,
          tokens_input: 0, tokens_output: 0, cost_cents: 0,
          error: `cost-cap-exceeded:${e.remainingCents()}`,
        })
        return { tokens_input: 0, tokens_output: 0, cost_cents: 0, error: e.message }
      })()
      return { stream: errStream, finalized }
    }
    throw e
  }

  // Provider call with streaming. We tee the stream to count tokens while
  // passing through to the HTTP response.
  const raw = await callProvider(options, messages, allowlist)
  const [forClient, forCounting] = raw.tee()

  const startedAt = Date.now()
  const finalized = (async () => {
    let tokensOut = 0
    let assembled = ''
    const reader = forCounting.getReader()
    const decoder = new TextDecoder()
    try {
      while (true) {
        const { done, value } = await reader.read()
        if (done) break
        const chunk = decoder.decode(value, { stream: true })
        assembled += chunk
        tokensOut += approxTokens(chunk)
      }
    } catch (err) {
      const errMsg = err instanceof Error ? err.message : 'provider-error'
      await supabase.from('ai_usage_log').insert({
        tenant_id: options.tenantId, user_id: options.userId,
        conversation_id: options.conversationId,
        provider: options.provider, model: options.model,
        tokens_input: tokensInEst, tokens_output: tokensOut, cost_cents: 0,
        error: errMsg, latency_ms: Date.now() - startedAt,
      })
      return { tokens_input: tokensInEst, tokens_output: tokensOut, cost_cents: 0, error: errMsg }
    }

    // Final counts (exact from response where the provider reports them — placeholder uses approx)
    const tokensIn = tokensInEst
    const cost = estimatePendingCost({
      tokensInputEstimate: tokensIn,
      tokensOutputEstimate: tokensOut,
      rateCentsPerInput1k: allowlist.rate_cents_per_input_1k,
      rateCentsPerOutput1k: allowlist.rate_cents_per_output_1k,
    })

    // AP-AI-02: ALWAYS write ai_usage_log
    await supabase.from('ai_usage_log').insert({
      tenant_id: options.tenantId, user_id: options.userId,
      conversation_id: options.conversationId,
      provider: options.provider, model: options.model,
      tokens_input: tokensIn, tokens_output: tokensOut, cost_cents: cost,
      latency_ms: Date.now() - startedAt,
    })

    // Persist assistant message
    await supabase.from('messages').insert({
      conversation_id: options.conversationId,
      tenant_id: options.tenantId,
      role: 'assistant',
      content: assembled,
      model: options.model,
      tokens_input: tokensIn,
      tokens_output: tokensOut,
      cost_cents: cost,
      finish_reason: 'stop',
    })

    // Increment conversation totals
    await supabase.rpc('increment_conversation_totals', {
      p_conversation_id: options.conversationId,
      p_tokens_in: tokensIn,
      p_tokens_out: tokensOut,
      p_cost_cents: cost,
    })

    return { tokens_input: tokensIn, tokens_output: tokensOut, cost_cents: cost }
  })()

  return { stream: forClient, finalized }
}

function errorStream(message: string): ReadableStream<Uint8Array> {
  return new ReadableStream({
    start(controller) {
      controller.enqueue(new TextEncoder().encode(`event: error\ndata: ${JSON.stringify({ error: message })}\n\n`))
      controller.close()
    },
  })
}

// --- provider-specific fetch helpers (scaffolder fills in real impl) --------

async function callAnthropic(model: string, messages: RelayMessage[], opts: { temperature?: number; max_tokens: number }) {
  const res = await fetch('https://api.anthropic.com/v1/messages', {
    method: 'POST',
    headers: {
      'content-type': 'application/json',
      'x-api-key': process.env.ANTHROPIC_API_KEY ?? '',
      'anthropic-version': '2023-06-01',
    },
    body: JSON.stringify({ model, messages, max_tokens: opts.max_tokens, temperature: opts.temperature, stream: true }),
  })
  if (!res.ok || !res.body) throw new Error(`anthropic-http-${res.status}`)
  return res.body
}

async function callOpenAi(model: string, messages: RelayMessage[], opts: { temperature?: number; max_tokens: number }) {
  const res = await fetch('https://api.openai.com/v1/chat/completions', {
    method: 'POST',
    headers: { 'content-type': 'application/json', authorization: `Bearer ${process.env.OPENAI_API_KEY ?? ''}` },
    body: JSON.stringify({ model, messages, max_tokens: opts.max_tokens, temperature: opts.temperature, stream: true }),
  })
  if (!res.ok || !res.body) throw new Error(`openai-http-${res.status}`)
  return res.body
}

async function callGoogle(model: string, messages: RelayMessage[], opts: { temperature?: number; max_tokens: number }) {
  const res = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/${model}:streamGenerateContent?key=${process.env.GOOGLE_API_KEY ?? ''}`, {
    method: 'POST',
    headers: { 'content-type': 'application/json' },
    body: JSON.stringify({ contents: messages, generationConfig: { temperature: opts.temperature, maxOutputTokens: opts.max_tokens } }),
  })
  if (!res.ok || !res.body) throw new Error(`google-http-${res.status}`)
  return res.body
}
