// @{{product_name}}/ui/lib/cn — shared className merger
//
// Thin wrapper over clsx + tailwind-merge. Every design-system primitive
// (web + mobile) uses this to combine className inputs while resolving
// Tailwind conflict pairs (e.g., `p-2` + `p-4` → `p-4`).

import { clsx, type ClassValue } from "clsx";
import { twMerge } from "tailwind-merge";

export function cn(...inputs: ClassValue[]): string {
  return twMerge(clsx(inputs));
}
